{
  "skill": "meeting-doc",
  "parity_goal": "Preserve practical meeting prep, closeout, history, and review documents grounded in supplied context without assuming private meeting infrastructure.",
  "cases": [
    {
      "id": "prep-from-context",
      "prompt": "meeting-doc prep from these notes before my client check-in...",
      "expected_nodes": [
        "nodes/input-handling.md",
        "nodes/prep.md",
        "nodes/writing-standards.md"
      ],
      "expected_output_shape": [
        "Prep Brief",
        "What This Is",
        "Talking Points / Decisions",
        "Watchouts"
      ]
    },
    {
      "id": "closeout-from-notes",
      "prompt": "meeting-doc close this meeting from the notes below...",
      "expected_nodes": [
        "nodes/input-handling.md",
        "nodes/close.md",
        "nodes/writing-standards.md"
      ],
      "expected_output_shape": [
        "Meeting Closeout",
        "Decisions",
        "Commitments",
        "Suggested Follow-Up"
      ]
    },
    {
      "id": "history-from-supplied-notes",
      "prompt": "meeting-doc history across these three prior meeting notes...",
      "expected_nodes": [
        "nodes/history.md",
        "nodes/writing-standards.md"
      ],
      "expected_output_shape": [
        "Meeting History",
        "relevant prior meetings",
        "open threads"
      ]
    },
    {
      "id": "review-patterns",
      "prompt": "meeting-doc review client meetings from these notes and tell me what keeps recurring.",
      "expected_nodes": [
        "nodes/review.md",
        "nodes/writing-standards.md"
      ],
      "expected_output_shape": [
        "Meeting Review",
        "Pattern",
        "Recommended Adjustment"
      ]
    }
  ]
}
